# Asana Access Token
# Get your token from: https://app.asana.com/0/my-apps
ASANA_ACCESS_TOKEN=your_token_here

# Default Workspace GID (optional)
ASANA_WORKSPACE=

# GitHub token for `asana feedback` (optional)
# When set, `asana feedback` files the issue via the GitHub API instead of
# opening a browser. Needs "repo" (or "public_repo") scope.
# Create one at: https://github.com/settings/tokens
# GITHUB_TOKEN=
